{
  "framework": "nextjs",
  "installCommand": "npm install --legacy-peer-deps",
  "redirects": [
    { "source": "/(.*)", "has": [{ "type": "host", "value": "www.aidesignqa.com" }], "destination": "https://aidesignqa.com/:path*", "permanent": true },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "www.lp.aidesignqa.com" }], "destination": "https://lp.aidesignqa.com/:path*", "permanent": true }
  ]
}
