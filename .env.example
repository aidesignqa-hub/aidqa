# Environment Variables Configuration

# ============================================
# FRONTEND CONFIGURATION (Vercel/Vite)
# ============================================
# VITE_API_BASE_URL=https://your-project.supabase.co/functions/v1/aidqa-api
VITE_API_BASE_URL=

# ============================================
# SUPABASE EDGE FUNCTION SECRETS
# ============================================
# Set these using: supabase secrets set <KEY>=<VALUE>
# DO NOT commit these values to git!

# Supabase Configuration (Required)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Storage Bucket Name (Required, default: visual)
# STORAGE_BUCKET=visual

# Remote Browser WebSocket Endpoint (Required for URL scans)
# Get from Browserless.io or similar service
# BROWSERLESS_WS_ENDPOINT=wss://chrome.browserless.io?token=YOUR_TOKEN

# CORS Configuration (Optional)
# Comma-separated list of allowed origins, or '*' for all
# ALLOWED_ORIGINS=https://aidqa.vercel.app,http://localhost:8080

# AI Insights — Google Gemini (Required)
# GEMINI_API_KEY=your-google-ai-studio-key
# GEMINI_MODEL=gemini-2.0-flash
