{
  "name": "aidqa",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "npm run dev --workspace=apps/app",
    "build": "npm run build --workspace=apps/app",
    "test": "npm run test --workspace=apps/app",
    "lint": "npm run lint --workspace=apps/app",
    "supabase:functions": "npx supabase functions serve aidqa-api --no-verify-jwt",
    "supabase:deploy": "npx supabase functions deploy aidqa-api --no-verify-jwt"
  }
}
